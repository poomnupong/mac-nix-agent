# ── Host user IDs (for file permission mapping) ──────────
# Auto-detected by run.sh via `id -u` / `id -g` — no need to set here.
# Override only if you need a non-default mapping.
# HERMES_UID=501
# HERMES_GID=20

# ── LLM Provider ─────────────────────────────────────────
# Option A: Local inference (oMLX, Ollama, LM Studio, vLLM)
#   Set base_url in config.yaml to http://host.container.internal:<port>/v1
#   OMLX_API_KEY is referenced by config.yaml providers.omlx.key_env.
OMLX_API_KEY=

# Option B: Ollama Cloud (no local GPU needed)
#   Set provider: ollama-cloud in config.yaml
OLLAMA_API_KEY=

# Option C: External API (OpenAI, Together, Groq, etc.)
#   Set provider: custom + base_url in config.yaml
# OPENAI_API_KEY=sk-...

# ── Tool Services (built into the container) ─────────────
SEARXNG_URL=http://localhost:8080
CAMOFOX_URL=http://localhost:9377

# ── Optional ─────────────────────────────────────────────
# FIRECRAWL_API_KEY=fc-...
