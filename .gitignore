result

# Per-machine flake personalization (username, hostname). Written by
# bootstrap.sh; flake.nix imports it via `builtins.pathExists` so the
# tracked flake stays clean for upstream pulls.
local.nix

# Hermes secrets (contains API keys)
hermes/.env

# Hermes runtime data (sessions, state.db, agent memories — all private)
# Dir is re-created by run.sh on first `hermes-up`.
hermes/data/

# Hermes workspace (user I/O files)
hermes/workspace/

# Local customizations (per-machine, not for upstream)
hermes/config.yaml.custom

# macOS
.DS_Store
